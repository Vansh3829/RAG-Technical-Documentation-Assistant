# --- Required: get a free API key at https://console.groq.com/keys ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.0

# --- Embeddings run 100% locally, no key needed ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Vector store ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=tech_docs

# --- Ingestion / retrieval ---
CORPUS_DIR=./data/corpus
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4

# --- Self-corrective workflow ---
MAX_RETRIES=2

# --- Optional bonus: free web search fallback ---
# Get a free key (1,000 searches/month) at https://tavily.com
TAVILY_API_KEY=
ENABLE_WEB_SEARCH_FALLBACK=true

# --- Feedback storage ---
FEEDBACK_DB_PATH=./feedback.db
